# 外部任务接入网关（阶段 6A）鉴权 Key。
#
# 用于 POST /api/v1/integrations/tasks/submit 请求头
# X-Task-API-Key 的服务端比对值；backend 只从进程环境变量读取，
# 不会自动加载本文件（本项目当前没有 dotenv 加载机制）——请通过
# 部署环境自身的方式（shell export、docker-compose environment、
# systemd EnvironmentFile 等）设置该变量。
#
# 本文件只是占位说明，不包含真实 Key，也不要把真实 Key 提交到
# 版本库。未配置该变量时，外部任务接入网关会对所有请求返回 503。
EXTERNAL_TASK_API_KEY=

# SQLAlchemy engine 是否输出完整 SQL 语句和绑定参数。
#
# 默认关闭（未设置或设为 false/0/no/off 均视为关闭），因为开启后
# 会在日志中打印任务 payload、context、task 文本等业务数据。
# 仅建议在本地短期排查具体 SQL 问题时临时设为 true/1/yes/on，
# 不建议在包含真实业务数据的环境中开启。
SQLALCHEMY_ECHO=false

# 企业微信自建应用回调（阶段 7B）所需的 5 项凭据，均需在企业微信
# 管理后台（work.weixin.qq.com）自行生成，详见
# docs/integrations/wecom-ai-secretariat.md。5 项必须同时配置，
# 任一缺失时 /api/v1/integrations/wecom/callback 会对所有请求
# 返回 503。不要把真实值提交到版本库。
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_APP_SECRET=
WECOM_CALLBACK_TOKEN=
WECOM_ENCODING_AES_KEY=

# backend 调用 n8n"AI秘书处｜企业微信指令入口" Webhook 所需的
# 地址与鉴权。该 Webhook 只允许被 backend 调用，鉴权值需要与 n8n
# 里 "AI Secretariat WeCom Command Auth" Credential 的值一致。
WECOM_N8N_WEBHOOK_URL=
WECOM_N8N_WEBHOOK_AUTH_HEADER=
WECOM_N8N_WEBHOOK_AUTH_VALUE=

# 统一 LLM Gateway（阶段 8A）。LLM_PROVIDER 未设置或设置为
# deepseek/ollama 之外的值时，AI CEO 调用模型会安全失败
# （configuration_error），不会静默回退到另一个 Provider。
LLM_PROVIDER=

# DeepSeek（LLM_PROVIDER=deepseek 时必须配置 DEEPSEEK_API_KEY，
# 未配置时安全失败）。不要把真实 Key 提交到版本库。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Ollama（LLM_PROVIDER=ollama 时必须配置 OLLAMA_MODEL 为本机
# 已安装的模型名，例如 `docker exec ollama ollama list` 的输出；
# 未配置或模型未安装时安全失败，不会自动拉取模型）。
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=

# 请求超时（秒）与单次生成最大 token 数，均有内置默认值
# （60 / 2000），一般不需要修改。
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=2000
